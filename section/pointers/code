#include <iostream>

int main()
{
    int* p_name = new int;
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    *p_name = 1;
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    p_name = new int(42);
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    *p_name = 55;
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    int value = 100;
       
    std::cout << "Address: " << &value << " Value: " << value << std::endl;

    p_name = &value;
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    *p_name = 102;
    std::cout << "Address: " << &value << " Value: " << value << std::endl;
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    value = 104;
    std::cout << "Address: " << &value << " Value: " << value << std::endl;
    std::cout << "Address: " << p_name << " Value: " << *p_name << std::endl;

    std::cout << "Dereference of Pointer: " << &p_name << std::endl;
    
}